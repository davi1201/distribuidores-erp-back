enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAID
  PENDING_PAYMENT
  ENDED
  PAST_DUE
}

model Subscription {
  id String @id @default(uuid())

  // ID da assinatura (Stripe: sub_... | Asaas: sub_... ou installment_...)
  externalId String @unique
  // ID do cliente no gateway (Stripe: cus_... | Asaas: cus_...)
  customerId String
  status     String // active, past_due, canceled

  // 👇 NOVO: Identifica qual gateway processou essa assinatura
  gateway String @default("STRIPE") // "STRIPE" ou "ASAAS"

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Invoice   Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id         String  @id @default(uuid())
  externalId String  @unique // O ID "inv_..." da Pagar.me
  amount     Decimal @db.Decimal(10, 2)
  status     String // paid, pending, failed

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  createdAt DateTime @default(now())

  @@map("invoices")
}

// Adicione ao seu schema.prisma

model PaymentTerm {
  id          String  @id @default(uuid())
  tenantId    String
  name        String // Ex: "30/60/90 dias"
  description String?
  type        String // 'PAYABLE', 'RECEIVABLE', 'BOTH'
  isActive    Boolean @default(true)

  // --- MELHORIAS DE ERP ---

  // Valor mínimo para esta condição ser liberada (Ex: 3x apenas acima de R$ 300)
  minAmount Decimal @default(0) @db.Decimal(15, 2)

  // Quantidade de parcelas que essa regra gera (facilita filtros e queries)
  installmentsCount Int @default(1)

  // Se true, permite que o vendedor altere as datas manualmente no ato da venda
  isFlexible Boolean @default(false)

  // Estrutura: [{"days": 30, "percent": 50}, {"days": 60, "percent": 50}]
  rules Json

  // Relação N:N - Restringe quais métodos aceitam esta condição
  // Se vazio, aceita todos. Se tiver "Boleto", essa condição só aparece se o Meio for Boleto.
  allowedMethods TenantPaymentMethod[] @relation("TermToMethod")

  Tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  titles       FinancialTitle[]
  movements    FinancialMovement[]
  orders       Order[]
  OrderPayment OrderPayment[]

  @@map("payment_terms")
}
