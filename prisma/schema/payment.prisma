model SystemPaymentMethod {
  id            String                @id @default(uuid())
  name          String
  code          String                @unique
  isAcquirer    Boolean               @default(false)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  tenantMethods TenantPaymentMethod[]

  @@map("system_payment_methods")
}

model TenantPaymentMethod {
  id                    String   @id @default(uuid())
  tenantId              String
  systemPaymentMethodId String
  customName            String?
  isActive              Boolean  @default(true)
  maxInstallments       Int      @default(1)
  minInstallmentValue   Decimal  @default(0) @db.Decimal(10, 2)
  passFeeToCustomer     Boolean  @default(false)
  isAnticipated         Boolean  @default(true)
  isConfigured          Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Configurações de Boleto / PIX
  discountPercentage Decimal @default(0) @db.Decimal(5, 2) // % desconto pagamento em dia
  interestRatePerDay Decimal @default(0) @db.Decimal(6, 4) // % mora/dia (0.0333 = 1%/mês)
  finePercentage     Decimal @default(0) @db.Decimal(5, 2) // % multa atraso (máx legal 2%)
  dueDays            Int     @default(3) // dias para vencimento

  FinancialMovement   FinancialMovement[]
  FinancialTitle      FinancialTitle[]
  OrderPayment        OrderPayment[]
  installments        TenantPaymentInstallment[]
  systemPaymentMethod SystemPaymentMethod        @relation(fields: [systemPaymentMethodId], references: [id])
  tenant              Tenant                     @relation(fields: [tenantId], references: [id])
  allowedPaymentTerms PaymentTerm[]              @relation("TermToMethod")

  @@unique([tenantId, systemPaymentMethodId])
  @@map("tenant_payment_methods")
}

model TenantPaymentInstallment {
  id                    String              @id @default(uuid())
  tenantPaymentMethodId String
  installment           Int
  feePercentage         Decimal             @db.Decimal(5, 2)
  receiveInDays         Int                 @default(30)
  tenantPaymentMethod   TenantPaymentMethod @relation(fields: [tenantPaymentMethodId], references: [id], onDelete: Cascade)

  @@unique([tenantPaymentMethodId, installment])
  @@map("tenant_payment_installments")
}

model PaymentTerm {
  id                 String                @id @default(uuid())
  tenantId           String
  name               String
  description        String?
  type               String
  isActive           Boolean               @default(true)
  minAmount          Decimal               @default(0) @db.Decimal(15, 2)
  installmentsCount  Int                   @default(1)
  isFlexible         Boolean               @default(false)
  rules              Json
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  discountDays       Int                   @default(0)
  discountPercentage Decimal               @default(0) @db.Decimal(5, 2)
  finePercentage     Decimal               @default(0) @db.Decimal(5, 2)
  instructions       String?
  interestPercentage Decimal               @default(0) @db.Decimal(5, 2)
  movements          FinancialMovement[]
  titles             FinancialTitle[]
  OrderPayment       OrderPayment[]
  orders             Order[]
  Tenant             Tenant                @relation(fields: [tenantId], references: [id])
  allowedMethods     TenantPaymentMethod[] @relation("TermToMethod")

  @@map("payment_terms")
}
