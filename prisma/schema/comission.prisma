model CommissionRule {
  id                String          @id @default(uuid())
  tenantId          String
  name              String
  scope             CommissionScope @default(GLOBAL)
  type              CommissionType
  percentage        Decimal?        @db.Decimal(5, 2)
  fixedValue        Decimal?        @db.Decimal(10, 2)
  isActive          Boolean         @default(true)
  specificUserId    String?
  specificProductId String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("commission_rules")
}

model CommissionRecord {
  id                String            @id @default(uuid())
  tenantId          String
  sellerId          String
  orderId           String            @unique
  calculationBase   Decimal           @db.Decimal(10, 2)
  appliedPercentage Decimal           @default(0) @db.Decimal(5, 2)
  commissionAmount  Decimal           @db.Decimal(10, 2)
  status            CommissionStatus  @default(PENDING)
  referenceDate     DateTime
  dueDate           DateTime?
  paidAt            DateTime?
  payoutId          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  order             Order             @relation(fields: [orderId], references: [id])
  payout            CommissionPayout? @relation(fields: [payoutId], references: [id])
  seller            User              @relation(fields: [sellerId], references: [id])
  tenant            Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId, sellerId, status])
  @@index([referenceDate])
  @@map("commission_records")
}

model CommissionPayout {
  id          String             @id @default(uuid())
  tenantId    String
  sellerId    String
  totalAmount Decimal            @db.Decimal(10, 2)
  notes       String?
  receiptUrl  String?
  paidAt      DateTime           @default(now())
  seller      User               @relation(fields: [sellerId], references: [id])
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  records     CommissionRecord[]

  @@map("commission_payouts")
}

enum CommissionType {
  PERCENTAGE
  FIXED
  HYBRID
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELED
}

enum CommissionScope {
  GLOBAL
  SELLER
  PRODUCT
}
