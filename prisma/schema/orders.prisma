model Order {
  id               String            @id @default(uuid())
  code             Int               @default(autoincrement())
  customerId       String
  paymentTermId    String?
  priceListId      String
  subtotal         Decimal           @db.Decimal(10, 2)
  discount         Decimal           @default(0) @db.Decimal(10, 2)
  shipping         Decimal           @default(0) @db.Decimal(10, 2)
  total            Decimal           @db.Decimal(10, 2)
  totalIcms        Decimal           @default(0) @db.Decimal(10, 2)
  totalIpi         Decimal           @default(0) @db.Decimal(10, 2)
  status           OrderStatus       @default(DRAFT)
  tenantId         String
  sellerId         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  commissionRecord CommissionRecord?
  financialTitles  FinancialTitle[]
  items            OrderItem[]
  payments         OrderPayment[]
  nfes             NfeEmitida[]
  customer         Customer          @relation(fields: [customerId], references: [id])
  paymentTerm      PaymentTerm?      @relation(fields: [paymentTermId], references: [id])
  priceList        PriceList         @relation(fields: [priceListId], references: [id])
  seller           User?             @relation("SellerOrders", fields: [sellerId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, sellerId])
  @@index([tenantId, createdAt])
  @@map("orders")
}

model OrderItem {
  id           String       @id @default(uuid())
  orderId      String
  productId    String
  quantity     Decimal      @db.Decimal(10, 4)
  unitPrice    Decimal      @db.Decimal(10, 2)
  discount     Decimal      @default(0) @db.Decimal(10, 2)
  totalPrice   Decimal      @db.Decimal(10, 2)
  deliveryType DeliveryType @default(READY)
  icmsRate     Decimal      @default(0) @db.Decimal(5, 2)
  ipiRate      Decimal      @default(0) @db.Decimal(5, 2)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderPayment {
  id                    String              @id @default(uuid())
  tenantId              String
  orderId               String
  tenantPaymentMethodId String
  baseAmount            Decimal             @db.Decimal(10, 2)
  installments          Int                 @default(1)
  discountApplied       Decimal             @default(0) @db.Decimal(10, 2)
  feeApplied            Decimal             @default(0) @db.Decimal(10, 2)
  finalAmount           Decimal             @db.Decimal(10, 2)
  paymentTermId         String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  titles                FinancialTitle[]
  order                 Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentTerm           PaymentTerm?        @relation(fields: [paymentTermId], references: [id])
  tenant                Tenant              @relation(fields: [tenantId], references: [id])
  tenantPaymentMethod   TenantPaymentMethod @relation(fields: [tenantPaymentMethodId], references: [id])

  @@map("order_payments")
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  SEPARATION
  INVOICED
  CANCELED
  COMPLETED
}

enum DeliveryType {
  READY
  PRE_ORDER
}
