model User {
  id                  String                @id @default(uuid())
  name                String
  email               String                @unique
  password            String?
  role                Role                  @default(ADMIN)
  phone               String?
  clerkId             String?               @unique
  googleId            String?               @unique
  avatarUrl           String?
  isActive            Boolean               @default(true)
  tenantId            String?
  permissions         String[]              @default([])
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  auditLogs           AuditLog[]
  CommissionPayout    CommissionPayout[]
  CommissionRecord    CommissionRecord[]
  customers           Customer[]
  FinancialMovement   FinancialMovement[]
  createdTitles       FinancialTitle[]      @relation("UserCreatedTitles")
  sales               Order[]               @relation("SellerOrders")
  ProductPriceHistory ProductPriceHistory[]
  SellerProfile       SellerProfile?
  StockMovement       StockMovement[]
  transfersApproved   StockTransfer[]       @relation("ApproverUser")
  transfersReceived   StockTransfer[]       @relation("ReceiverUser")
  transfersRequested  StockTransfer[]       @relation("RequesterUser")
  StockTransfer       StockTransfer[]
  tenant              Tenant?               @relation(fields: [tenantId], references: [id])
  Warehouse           Warehouse[]
  NfeEmitida          NfeEmitida[]
  NfeInutilizacao     NfeInutilizacao[]

  @@map("users")
}

model SellerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  whatsapp       String?
  cpf            String?
  commissionRate Decimal  @default(0.0)
  maxDiscount    Decimal  @default(10.0)
  monthlyGoal    Decimal?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("seller_profiles")
}

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  SELLER
  SUPPORT
}
