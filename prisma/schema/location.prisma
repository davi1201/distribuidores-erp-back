model State {
  id              Int              @id @default(autoincrement())
  name            String
  uf              String           @unique
  billingProfiles BillingProfile[]
  cities          City[]
  Address         Address[]

  @@map("states")
}

model City {
  id              Int              @id @default(autoincrement())
  name            String
  stateId         Int
  ibgeCode        String           @unique
  billingProfiles BillingProfile[]
  state           State            @relation(fields: [stateId], references: [id])
  Address         Address[]

  @@map("cities")
}
