model WebhookEvent {
  id           String        @id @default(uuid())
  provider     String
  eventType    String
  payload      Json
  status       WebhookStatus @default(PENDING)
  errorMessage String?
  tenantId     String?
  externalId   String?
  createdAt    DateTime      @default(now())
  processedAt  DateTime?
}

enum WebhookStatus {
  PENDING
  PROCESSED
  FAILED
}
