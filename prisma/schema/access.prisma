model Invite {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  name      String
  role      Role
  tenantId  String
  metadata  Json?
  expiresAt DateTime
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@map("invites")
}
