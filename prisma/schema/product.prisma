model Product {
  id                String                @id @default(uuid())
  tenantId          String
  name              String
  description       String?
  sku               String
  ean               String?
  brand             String?
  unit              String                @default("UN")
  parentId          String?
  variantName       String?
  ncmCode           String
  cestCode          String?
  cfopCode          String?
  ncm               Ncm                   @relation(fields: [ncmCode], references: [code])
  cest              Cest?                 @relation(fields: [cestCode], references: [code])
  cfop              Cfop?                 @relation(fields: [cfopCode], references: [code])
  origin            Int                   @default(0)
  taxProfileId      String?
  costPrice         Decimal               @default(0) @db.Decimal(10, 4)
  expenses          Decimal               @default(0) @db.Decimal(10, 4)
  markup            Decimal               @default(0) @db.Decimal(10, 4)
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  OrderItem         OrderItem[]
  images            ProductImage[]
  priceHistory      ProductPriceHistory[]
  prices            ProductPrice[]
  supplier          ProductSupplier?
  parent            Product?              @relation("ProductVariants", fields: [parentId], references: [id])
  variants          Product[]             @relation("ProductVariants")
  taxProfile        TaxProfile?           @relation(fields: [taxProfileId], references: [id])
  tenant            Tenant                @relation(fields: [tenantId], references: [id])
  stock             StockItem[]
  movements         StockMovement[]
  StockTransferItem StockTransferItem[]

  @@unique([tenantId, sku])
  @@index([tenantId, name])
  @@index([tenantId, isActive])
  @@index([tenantId, parentId])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  order     Int      @default(0)
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductPrice {
  id          String    @id @default(uuid())
  price       Decimal   @db.Decimal(10, 4)
  productId   String
  tenantId    String
  priceListId String
  updatedAt   DateTime  @updatedAt
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([productId, priceListId])
  @@map("product_prices")
}

model ProductPriceHistory {
  id          String    @id @default(uuid())
  oldPrice    Decimal?  @db.Decimal(10, 4)
  newPrice    Decimal   @db.Decimal(10, 4)
  reason      String?
  productId   String
  priceListId String
  changedBy   String?
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [changedBy], references: [id])
  priceList   PriceList @relation(fields: [priceListId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@map("product_price_history")
}

model TaxProfile {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  description String?
  products    Product[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  rules       TaxRule[]

  @@map("tax_profiles")
}

model TaxRule {
  id               String     @id @default(uuid())
  taxProfileId     String
  originState      String
  destinationState String
  icmsRate         Decimal    @default(0) @db.Decimal(5, 2)
  ipiRate          Decimal    @default(0) @db.Decimal(5, 2)
  pisRate          Decimal    @default(0) @db.Decimal(5, 2)
  cofinsRate       Decimal    @default(0) @db.Decimal(5, 2)
  updatedAt        DateTime   @updatedAt
  taxProfile       TaxProfile @relation(fields: [taxProfileId], references: [id], onDelete: Cascade)

  @@unique([taxProfileId, originState, destinationState])
  @@map("tax_rules")
}

model StockItem {
  id          String    @id @default(uuid())
  productId   String
  quantity    Decimal   @default(0) @db.Decimal(10, 4)
  minStock    Decimal   @default(0) @db.Decimal(10, 4)
  maxStock    Decimal?  @db.Decimal(10, 4)
  updatedAt   DateTime  @updatedAt
  warehouseId String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@map("stock_items")
}
