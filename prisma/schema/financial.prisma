model FinancialCategory {
  id          String           @id @default(uuid())
  tenantId    String
  name        String
  type        CategoryType
  description String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  titles      FinancialTitle[]

  @@map("financial_categories")
}

model FinancialTitle {
  id                    String               @id @default(uuid())
  tenantId              String
  importId              String?
  origin                TitleOrigin          @default(MANUAL)
  titleNumber           String
  description           String?
  installmentNumber     Int?                 @default(1)
  totalInstallments     Int?                 @default(1)
  type                  TitleType            @default(RECEIVABLE)
  customerId            String?
  supplierId            String?
  categoryId            String?
  orderId               String?
  orderPaymentId        String?
  tenantPaymentMethodId String?
  paymentTermId         String?
  asaasPaymentId        String?
  boletoUrl             String?
  pixCopyPaste          String?
  invoiceUrl            String?
  createdById           String?
  originalAmount        Decimal              @db.Decimal(10, 2)
  balance               Decimal              @db.Decimal(10, 2)
  paidAmount            Decimal              @default(0) @db.Decimal(10, 2)
  issueDate             DateTime             @default(now())
  dueDate               DateTime
  competenceDate        DateTime             @default(now())
  paidAt                DateTime?
  status                TitleStatus          @default(OPEN)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  movements             FinancialMovement[]
  category              FinancialCategory?   @relation(fields: [categoryId], references: [id])
  createdBy             User?                @relation("UserCreatedTitles", fields: [createdById], references: [id])
  customer              Customer?            @relation(fields: [customerId], references: [id])
  order                 Order?               @relation(fields: [orderId], references: [id])
  orderPayment          OrderPayment?        @relation(fields: [orderPaymentId], references: [id])
  paymentTerm           PaymentTerm?         @relation(fields: [paymentTermId], references: [id])
  supplier              Supplier?            @relation(fields: [supplierId], references: [id])
  tenant                Tenant               @relation(fields: [tenantId], references: [id])
  tenantPaymentMethod   TenantPaymentMethod? @relation(fields: [tenantPaymentMethodId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([orderId])
  @@map("financial_titles")
}

model FinancialMovement {
  id                    String               @id @default(uuid())
  tenantId              String
  titleId               String
  type                  MovementType
  amount                Decimal              @db.Decimal(10, 2)
  paymentDate           DateTime             @default(now())
  userId                String?
  observation           String?
  bankAccountId         String?
  tenantPaymentMethodId String?
  paymentTermId         String?
  reconciled            Boolean              @default(false)
  reconciledAt          DateTime?
  createdAt             DateTime             @default(now())
  BankTransaction       BankTransaction?
  bankAccount           BankAccount?         @relation(fields: [bankAccountId], references: [id])
  PaymentTerm           PaymentTerm?         @relation(fields: [paymentTermId], references: [id])
  tenant                Tenant               @relation(fields: [tenantId], references: [id])
  tenantPaymentMethod   TenantPaymentMethod? @relation(fields: [tenantPaymentMethodId], references: [id])
  title                 FinancialTitle       @relation(fields: [titleId], references: [id], onDelete: Cascade)
  user                  User?                @relation(fields: [userId], references: [id])

  @@map("financial_movements")
}

enum TitleStatus {
  OPEN
  PARTIAL
  PAID
  CANCELED
  OVERDUE
}

enum TitleType {
  RECEIVABLE
  PAYABLE
}

enum TitleOrigin {
  MANUAL
  ORDER
  PURCHASE
  IMPORT
}

enum MovementType {
  PAYMENT
  REVERSAL
  INTEREST
  DISCOUNT
  ADJUSTMENT
  RECEIPT
}

enum CategoryType {
  RECEIVABLE
  PAYABLE
}
