model Customer {
  id                    String            @id @default(uuid())
  code                  Int               @default(autoincrement())
  name                  String
  email                 String?
  phone                 String?
  personType            PersonType
  document              String?
  isActive              Boolean           @default(true)
  corporateName         String?
  tradeName             String?
  stateRegistration     String?
  municipalRegistration String?
  isExempt              Boolean           @default(false)
  isFinalConsumer       Boolean           @default(false)
  isICMSContributor     Boolean           @default(false)
  invoiceNotes          String?
  asaasId               String?
  priceListId           String?
  paymentConditionId    String?
  sellerId              String?
  creditLimit           Decimal           @default(0) @db.Decimal(10, 2)
  allowExceedLimit      Boolean           @default(false)
  tenantId              String
  categoryId            String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  addresses             Address[]
  attachments           Attachment[]
  contacts              Contact[]
  category              CustomerCategory? @relation(fields: [categoryId], references: [id])
  priceList             PriceList?        @relation(fields: [priceListId], references: [id])
  seller                User?             @relation(fields: [sellerId], references: [id])
  tenant                Tenant            @relation(fields: [tenantId], references: [id])
  financialTitles       FinancialTitle[]
  Order                 Order[]

  @@unique([document, tenantId])
  @@map("customers")
}

model Contact {
  id         String   @id @default(uuid())
  name       String?
  phone      String?
  role       String?
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_contacts")
}

model Address {
  id           String           @id @default(uuid())
  zipCode      String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  cityCode     Int?
  stateCode    Int?
  ibgeCode     String?
  categoryId   String?
  customerId   String
  category     AddressCategory? @relation(fields: [categoryId], references: [id])
  city         City?            @relation(fields: [cityCode], references: [id])
  customer     Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  state        State?           @relation(fields: [stateCode], references: [id])

  @@map("customer_addresses")
}

model AddressCategory {
  id              String    @id @default(uuid())
  description     String
  isSystemDefault Boolean   @default(false)
  isActive        Boolean   @default(true)
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  addresses       Address[]

  @@map("address_categories")
}

model CustomerCategory {
  id          String     @id @default(uuid())
  description String
  isActive    Boolean    @default(true)
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  customers   Customer[]

  @@map("customer_categories")
}

model Attachment {
  id         String   @id @default(uuid())
  name       String
  url        String
  customerId String
  createdAt  DateTime @default(now())
  tenantId   String?
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  Tenant     Tenant?  @relation(fields: [tenantId], references: [id])

  @@map("customer_attachments")
}

enum PersonType {
  PF
  PJ
}
