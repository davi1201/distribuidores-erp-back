model Tenant {
  id                            String                @id @default(uuid())
  slug                          String                @unique
  name                          String
  isActive                      Boolean               @default(true)
  clerkId                       String?               @unique
  logoUrl                       String?
  planId                        String
  trialEndsAt                   DateTime?
  asaasAccountId                String?
  asaasApiKey                   String?
  asaasWalletId                 String?
  asaasPixKey                   String?
  asaasOnboardingUrl            String?
  asaasAccountStatus            String                @default("PENDING")
  monthlyBoletoBalance          Int                   @default(0)
  extraBoletoBalance            Int                   @default(0)
  // PlugNotas Integration
  plugnotasApiKey               String?
  plugnotasEmpresaCnpj          String?
  plugnotasCertificadoValido    Boolean               @default(false)
  plugnotasCertificadoVencimento DateTime?
  plugnotasAmbiente             Int                   @default(2) // 1=Produção, 2=Homologação
  regimeTributario              Int                   @default(1) // 1=Simples Nacional, 2=Simples Excesso, 3=Regime Normal
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @updatedAt
  addressCategories             AddressCategory[]
  BankAccount                   BankAccount[]
  billingProfile                BillingProfile?
  CommissionPayout              CommissionPayout[]
  CommissionRecord              CommissionRecord[]
  CommissionRule                CommissionRule[]
  attachments                   Attachment[]
  customerCategories            CustomerCategory[]
  customers                     Customer[]
  FinancialCategory             FinancialCategory[]
  financialMovements            FinancialMovement[]
  financialTitles               FinancialTitle[]
  Invite                        Invite[]
  NfeInbox                      NfeInbox[]
  NfeEmitida                    NfeEmitida[]
  NfeInutilizacao               NfeInutilizacao[]
  OrderPayment                  OrderPayment[]
  Order                         Order[]
  PaymentTerm                   PaymentTerm[]
  priceLists                    PriceList[]
  ProductPrice                  ProductPrice[]
  ProductSupplier               ProductSupplier[]
  products                      Product[]
  StockMovement                 StockMovement[]
  StockTransfer                 StockTransfer[]
  subscriptions                 Subscription[]
  Supplier                      Supplier[]
  taxProfiles                   TaxProfile[]
  TenantEmailConfig             TenantEmailConfig?
  TenantPaymentMethod           TenantPaymentMethod[]
  plan                          Plan                  @relation(fields: [planId], references: [id])
  users                         User[]
  Warehouse                     Warehouse[]

  @@map("tenants")
}

model TenantEmailConfig {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  host      String
  port      Int      @default(993)
  user      String
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@map("tenant_email_configs")
}
